# Copy to .env and fill in real values before running `docker-compose up`.
# .env is git-ignored - never commit real secrets.

# JWT signing key (HS256, needs >= 256 bits). Generate with: openssl rand -base64 32
APP_JWT_SECRET=

# Kakao REST API key, used only to seed the book catalog once at startup (docs/ERD.md "도서 카탈로그 모듈").
# Optional - if left blank, seeding just logs a warning and skips; the app still starts normally.
# Get one at https://developers.kakao.com (앱 생성 -> 앱 키 -> REST API 키).
APP_KAKAO_REST_API_KEY=
